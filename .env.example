# Copy to .env and fill in. Never commit .env.

# Telegram bot token from @BotFather (required)
TELEGRAM_BOT_TOKEN=

# Whisper model — Hugging Face id, or a local CTranslate2 dir.
# Default is the Ukrainian fine-tune. Alternatives: large-v3-turbo, small
WHISPER_MODEL=large-v3-turbo

# Transcription language (forced; skips autodetect)
WHISPER_LANGUAGE=uk

# CPU/quantization tuning for the Raspberry Pi 5
WHISPER_COMPUTE_TYPE=int8
WHISPER_CPU_THREADS=4
WHISPER_BEAM_SIZE=1

# Optional: comma-separated Telegram user IDs allowed to use the bot.
# Leave empty to allow everyone (not recommended on a public bot).
ALLOWED_USER_IDS=
